# Typesense Cloud — get your cluster credentials from cloud.typesense.org
TYPESENSE_NODE_1=your-cluster-id-1.a1.typesense.net
TYPESENSE_NODE_2=your-cluster-id-2.a1.typesense.net
TYPESENSE_NODE_3=your-cluster-id-3.a1.typesense.net
TYPESENSE_PORT=443
TYPESENSE_PROTOCOL=https
TYPESENSE_API_KEY=your-admin-api-key

# Apify — required for web crawling. addresshotels.com is behind a WAF that
# blocks datacenter IPs, so the crawl runs through Apify RESIDENTIAL proxies
# (configured in scripts/apify_crawl.py). Get your token from:
# https://console.apify.com/account/integrations
APIFY_API_TOKEN=your-apify-api-token

# OpenAI — required for the Typesense conversation model (address-gpt uses GPT-4o)
OPENAI_API_KEY=your-openai-api-key

# Optional: HTTPS proxy for local requests (not used by the Apify crawl)
# HTTPS_PROXY=http://user:pass@proxy.example.com:8080
# NO_PROXY=your-typesense-node.typesense.net,api.openai.com
